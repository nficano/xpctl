import winreg
key_path = r'{{ reg_key }}'
value_name = r'{{ reg_name }}'
try:
    key = winreg.OpenKey(
        winreg.HKEY_LOCAL_MACHINE,
        key_path,
        0,
        winreg.KEY_SET_VALUE,
    )
    try:
        winreg.DeleteValue(key, value_name)
        result = {'removed': True}
    finally:
        winreg.CloseKey(key)
except OSError:
    result = {'removed': False, 'message': 'Startup entry not found'}
